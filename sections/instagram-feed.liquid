{{ 'instagram-feed.css' | asset_url | stylesheet_tag }}

<section
  class="instagram-feed-section{% if section.settings.enable_dark_mode %} is-dark{% endif %}"
  data-instagram-feed
  data-api-base="{{ section.settings.api_base_url | escape }}"
  data-layout="{{ section.settings.layout }}"
  data-columns-desktop="{{ section.settings.columns_desktop }}"
  data-columns-mobile="{{ section.settings.columns_mobile }}"
  data-gap="{{ section.settings.grid_gap }}"
  data-autoplay="{{ section.settings.autoplay_reels }}"
>
  <div class="instagram-feed-shell page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="instagram-feed-header">
        {% if section.settings.heading != blank %}
          <h2 class="instagram-feed-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="instagram-feed-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="instagram-feed-stage">
      <div class="instagram-feed-track" data-instagram-feed-track></div>
      <div class="instagram-feed-empty" data-instagram-feed-empty hidden>
        <p>No Instagram media is available right now.</p>
      </div>
    </div>
  </div>

  <div class="instagram-feed-modal" data-instagram-feed-modal hidden>
    <button class="instagram-feed-modal__backdrop" type="button" data-instagram-feed-close></button>
    <div class="instagram-feed-modal__dialog" role="dialog" aria-modal="true" aria-label="Instagram media preview">
      <button class="instagram-feed-modal__close" type="button" data-instagram-feed-close>Close</button>
      <div class="instagram-feed-modal__content" data-instagram-feed-modal-content></div>
    </div>
  </div>
</section>

<script src="{{ 'instagram-feed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Instagram Feed SaaS",
  "tag": "section",
  "class": "section-instagram-feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop our Instagram moments"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated posts and reels selected from the InstaLayer dashboard."
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "App base URL",
      "default": "https://your-render-service.onrender.com"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Mobile columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 18
    },
    {
      "type": "checkbox",
      "id": "autoplay_reels",
      "label": "Autoplay reels",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_dark_mode",
      "label": "Enable dark mode styling",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed SaaS"
    }
  ]
}
{% endschema %}