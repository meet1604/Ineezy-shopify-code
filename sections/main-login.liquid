{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  }
{%- endstyle -%}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="auth-wrapper">
  <div class="auth-card section-{{ section.id }}-padding">
    <!-- Login Start -->
    <div class="signinform">
      {% comment %}
        <div class="auth-title">
          <h1 id="login">
            {{ 'customer.login_page.title' | t }}
          </h1>
          <p>{{ 'customer.login_page.sub_title' | t }}</p>
        </div>
      {% endcomment %}

      <div class="login ">
        {% comment %} Forgot Password {% endcomment %}
        <div id="recover" class="auth-title">
          <h1 tabindex="-1">
            {{ 'customer.recover_password.title' | t }}
          </h1>
          <p>
            {{ 'customer.recover_password.subtext' | t }}
          </p>
        </div>
        <div>
          {%- form 'recover_customer_password' -%}
            {% assign recover_success = form.posted_successfully? %}
            <div class="form-group">
              <label for="RecoverEmail">
                {{ 'customer.login_page.email' | t }}
              </label>
              <input
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                class="form-control"
                autocomplete="email"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="RecoverEmail-email-error"
                  autofocus
                {% endif %}
                placeholder="{{ 'customer.login_page.email' | t }}"
              >
            </div>
            {%- if form.errors -%}
              <small id="RecoverEmail-email-error" class="form__message">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{ form.errors.messages.form }}
              </small>
            {%- endif -%}
            <div class="auth-button-group">
              <button class="btn btn-outline-primary">
                {{ 'customer.login_page.submit' | t }}
              </button>
            </div>

            <div class="auth-bottom-link">
              <a href="#login" class="m-0">
                <i class="svg-wrapper">{{ 'arrow-left-2.svg' | inline_asset_content }}</i>
                Back to Sign In
              </a>
            </div>
          {%- endform -%}
        </div>
        {% comment %} Forgot Password {% endcomment %}

        {% comment %} Sing In {% endcomment %}
        <div id="login" class="auth-title">
          <h1 tabindex="-1">
            {{ 'customer.login_page.title' | t }}
          </h1>
          <p>Welcome back, you’re been missed!</p>
        </div>

        <div>
          {%- if recover_success == true -%}
            <h3 class="form__message" tabindex="-1" autofocus>
              <span class="svg-wrapper">
                {{- 'icon-success.svg' | inline_asset_content -}}
              </span>
              {{ 'customer.recover_password.success' | t }}
            </h3>
          {%- endif -%}
          {%- form 'customer_login', novalidate: 'novalidate' -%}
            {%- if form.errors -%}
              <h2 class="form__message" tabindex="-1" autofocus>
                <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
              {{ form.errors | default_errors }}
            {%- endif -%}

            {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
              <section name="sign-in-with-shop-provider">
                {{ shop | login_button: hide_button: hide_shop_login_button }}

                {%- unless hide_shop_login_button -%}
                  <p>
                    {{ 'customer.login_page.alternate_provider_separator' | t }}
                  </p>
                {%- endunless -%}
              </section>
            {%- endif -%}

            <div class="form-group">
              <label for="CustomerEmail">
                {{ 'customer.login_page.email' | t }}
              </label>
              <input
                type="email"
                name="customer[email]"
                id="CustomerEmail"
                autocomplete="email"
                autocorrect="off"
                class="form-control"
                autocapitalize="off"
                {% if form.errors contains 'form' %}
                  aria-invalid="true"
                {% endif %}
                placeholder="{{ 'customer.login_page.email' | t }}"
              >
            </div>

            {%- if form.password_needed -%}
              <div class="form-group">
                <label for="CustomerPassword">
                  {{ 'customer.login_page.password' | t }}
                </label>
                <input
                  type="password"
                  value=""
                  name="customer[password]"
                  id="CustomerPassword"
                  class="form-control"
                  autocomplete="current-password"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                  placeholder="{{ 'customer.login_page.password' | t }}"
                >
              </div>

                {% comment %} <a href="#recover" >
                  {{ 'customer.login_page.forgot_password' | t }}
                </a> {% endcomment %}
                <div class="auth-forgot-password">
                  <a href="#recover" class="forgot-password-link ms-auto">
                    {{ 'customer.login_page.forgot_password' | t }}
                  </a>
                </div>
            {%- endif -%}

            <div class="auth-button-group">
              <button class="btn btn-outline-primary">
                {{ 'customer.login_page.sign_in' | t }}
              </button>
            </div>

            <div class="auth-bottom-link">
              Don’t have Account?
              <a class="m-0" href="{{ routes.account_register_url }}">
                {{ 'customer.login_page.create_account' | t }}
                <i class="svg-wrapper">{{ 'arrow-right-2.svg' | inline_asset_content }}</i>
              </a>
            </div>
          {%- endform -%}
        </div>
        {% comment %} Sing In {% endcomment %}

        {%- if shop.checkout.guest_login -%}
          <div>
            <hr>
            <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

            {%- form 'guest_login' -%}
              <button>
                {{ 'customer.login_page.guest_continue' | t }}
              </button>
            {%- endform -%}
          </div>
        {%- endif -%}
      </div>
    </div>
    <!-- Login End -->
  </div>

  <!-- Guest Checkout -->
  {%- if shop.checkout.guest_login -%}
    <div>
      <hr>
      <h2>{{ 'customer.login_page.guest_title' | t }}</h2>
      {%- form 'guest_login' -%}
        <button>{{ 'customer.login_page.guest_continue' | t }}</button>
      {%- endform -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
