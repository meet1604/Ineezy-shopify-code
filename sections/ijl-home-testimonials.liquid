<section class="ijl-home-testimonials">
  <div class="container">
    <div class="main-title">
      <p class="mt-0 mb-2">Client Testimonials</p>
      <h2>Customer Review</h2>
    </div>

    <div class="ijl-home-testimonials-slider custom-slick-slider">
      {% for block in section.blocks %}
        <div class="ijl-home-testimonials-slider-card">
          <div class="testimonials-ratings">
            {% for i in (1..block.settings.rating) %}
              <img src="{{ 'new-icon-star.svg' | asset_url }}" alt="star" />
            {% endfor %}
          </div>
          <div class="testimonials-text">
            <h6>{{ block.settings.heading }}</h6>
            <p>"{{ block.settings.text }}"</p>
          </div>
          <div class="testimonials-client-details">
            <h6>{{ block.settings.name }}</h6>
            <p>{{ block.settings.location }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "IJL Home Testimonials",
  "settings": [],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Client Name",
          "default": "Michel Wooud"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location & Time",
          "default": "Los Angeles, 5 months ago"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Gorgeous"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Text",
          "default": "Mauris ut malesuada orem Ipsum estibulum..."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "IJL Home Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
