<section class="our-mission">
  <div class="container">
    <div class="main-title">
      <h2>{{ section.settings.heading }}</h2>
      <div>{{ section.settings.description }}</div>
    </div>

    <div class="our-mission-row row">
      {% for block in section.blocks %}
        <div class="our-mission-col col-lg-4 col-md-6 col-12">
          <div class="our-mission-card">
            <div class="our-mission-icon">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="{{ block.settings.title | escape }}">
              {% endif %}
            </div>
            <div class="our-mission-text">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "IJL About Our Mission",
  "tag": "section",
  "class": "our-mission-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Mission"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Section Description",
      "default": "<p>At International Jeweler Limited, our mission is to cultivate a more transparent, sustainable, compassionate, and inclusive jewelry industry. We believe in harmonizing quality with conscience, ensuring that our customers can cherish their jewelry with pride.​</p>"
    }
  ],
  "blocks": [
    {
      "type": "mission_point",
      "name": "Mission Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Transparency"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "We are committed to knowing and sharing the origins of our precious metals and gemstones, providing our customers with complete visibility into the sourcing and creation of their jewelry."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "IJL About Our Mission",
      "blocks": [
        {
          "type": "mission_point",
          "settings": {
            "title": "Transparency",
            "text": "We are committed to knowing and sharing the origins of our precious metals and gemstones, providing our customers with complete visibility into the sourcing and creation of their jewelry."
          }
        },
        {
          "type": "mission_point",
          "settings": {
            "title": "Sustainability",
            "text": "Our practices include using recycled and sustainable materials, implementing energy-efficient methods, and striving to minimize our carbon footprint, all to protect our planet for future generations."
          }
        },
        {
          "type": "mission_point",
          "settings": {
            "title": "Compassion",
            "text": "We care deeply about our communities, employees, and all those involved in bringing our jewelry to life, demonstrating our commitment through charitable contributions and volunteerism."
          }
        },
        {
          "type": "mission_point",
          "settings": {
            "title": "Inclusion",
            "text": "We foster a diverse and supportive environment, ensuring every team member feels valued, and we design our collections with inclusivity in mind, offering styles that resonate with a wide range of customers."
          }
        }
      ]
    }
  ]
}
{% endschema %}
