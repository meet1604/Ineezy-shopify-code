<section class="spring-collection " >
  <div class="spring-collection-wrapper ">
    <div class="spring-collection-image spring-collection-col">
      {% comment %} <img src="{{ 'collection2.png' | asset_url }}" alt="{{ block.settings.title }}" /> {% endcomment %}
      <img src="https://cdn.shopify.com/s/files/1/0618/9246/0587/files/IMG_3469.jpg?v=1760384501" alt="{{ block.settings.title }}" />
    </div>
    <div class="spring-collection-content spring-collection-col">
      <img class="spring-collection-content-bg" src="{{ 'spring-collection-bg.svg' | asset_url }}"  alt="imgae" />
        <div class="spring-collection-content-wrapper spring-collection-slider custom-slick-slider">
          
          {% for block in section.blocks %}
          <div class="spring-collection-content-inner">
              <h5>{{ block.settings.small_title }}</h5>
              <h2>{{ block.settings.title }}</h2>
              <p>{{ block.settings.description }}</p>
              <a href="{{ block.settings.link }}" class="btn btn-primary">Shop Bracelets <span class="banner-slider__button-arrow">→</span></a>
          </div>
          {% endfor %}
          
        </div>
    </div>
  </div>
</section>















{% schema %}
{
  "name": "Spring Collection Slider",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
          {
          "type": "text",
          "id": "small_title",
          "label": "Small Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
         
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Spring Collection Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}


