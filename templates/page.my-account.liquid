
<section class="my-account">
    <div class="container">
        <div class="my-account-title-wrapper">
            <div class="my-account-title-left">
                <div class="my-account-title">
                    <h6>My Account</h6>
                    <h2>Welcome {{ customer.first_name | default: 'Guest' }}!</h2>
                </div>
            </div>
            <div class="my-account-title-right">
                <form action="/account/logout" method="post">
                    <button type="submit" class="btn btn-outline-primary">
                        Log Out <i class="svg-wrapper">{{ 'arrow-right-2.svg' | inline_asset_content }}</i>
                    </button>
                </form>
            </div>
        </div>
        <div class="my-account-wrapper ">
            <div class="my-account-left">
                <div class="my-account-menu nav flex-column nav-pills me-3" id="v-pills-tab" role="tablist"
                    aria-orientation="vertical">
                    <h6 class="nav-title">MAIN</h6>
                    <button class="nav-link active" id="dashboard-tab" data-bs-toggle="pill" data-bs-target="#dashboard"
                        type="button" role="tab" aria-controls="dashboard" aria-selected="true">
                        <i class="svg-wrapper">{{ 'new-icon-dashboard.svg' | inline_asset_content }}</i> Dashboard
                    </button>
                    <h6 class="nav-title">ORDERS</h6>
                    <button class="nav-link" id="orders-tab" data-bs-toggle="pill" data-bs-target="#orders"
                        type="button" role="tab" aria-controls="orders" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-order.svg' | inline_asset_content }}</i> My Orders
                    </button>
                    <button class="nav-link d-none" id="returns-tab" data-bs-toggle="pill" data-bs-target="#returns"
                        type="button" role="tab" aria-controls="returns" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-return.svg' | inline_asset_content }}</i> Returns
                    </button>
                    <h6 class="nav-title">CREDITS</h6>
                    <button class="nav-link" id="offers-tab" data-bs-toggle="pill" data-bs-target="#offers"
                        type="button" role="tab" aria-controls="offers" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-offer.svg' | inline_asset_content }}</i> Offers/Coupons
                    </button>
                    <h6 class="nav-title">ACCOUNT</h6>
                    <button class="nav-link" id="profile-tab" data-bs-toggle="pill" data-bs-target="#profile"
                        type="button" role="tab" aria-controls="profile" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-account.svg' | inline_asset_content }}</i> Profile
                    </button>
                    <button class="nav-link" id="wishlist-tab" data-bs-toggle="pill" data-bs-target="#wishlist"
                        type="button" role="tab" aria-controls="wishlist" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-wishlist.svg' | inline_asset_content }}</i> Wishlist
                    </button>
                    <button class="nav-link" id="shipping-tab" data-bs-toggle="pill" data-bs-target="#shipping"
                        type="button" role="tab" aria-controls="shipping" aria-selected="false">
                        <i class="svg-wrapper">{{ 'new-icon-location.svg' | inline_asset_content }}</i> Shipping
                        Addresses
                    </button>
                </div>
            </div>

            <div class="my-account-right">
                <div class="tab-content" id="v-pills-tabContent">




                    <div class="tab-pane fade show active" id="dashboard" role="tabpanel"
                        aria-labelledby="dashboard-tab">


                      <div class="profile-card">
                            {% if customer %}
                            <div class="profile-card-image">
                                <img src="{{ 'default-profile.svg' | asset_url }}"
                                    alt="{{ customer.name }}'s Profile" class="profile-image">
                            </div>
                            <div class="profile-card-text">
                                <div class="profile-card-name">
                                    <h4>{{ customer.name }}</h4>
                                    <a href="/account/addresses" class="btn btn-primary"> <i class="svg-wrapper">{{ "new-icon-edit.svg" | inline_asset_content }}</i> Edit Profile</a>
                                </div>
                                <p> {{ customer.email }}</p>
                                <p>{{ customer.default_address.phone}}</p>
                                <p>{{ customer.default_address.address1 }}, {{ customer.default_address.city }}</p>
                            </div>
                            {% else %}
                            <p>Please log in to view your profile.</p>




                            {% endif %}
                        </div>


                      <div class="dashbaord">
                        <div class="dashbaord-card">
                          <i class="svg-wrapper">{{ "new-icon-order.svg" | inline_asset_content }}</i>
                          <h6>My Shoped Orders</h6>
                          <p>Check your order status</p>
                        </div>
                        <div class="dashbaord-card">
                          <i class="svg-wrapper">{{ "new-icon-order-2.svg" | inline_asset_content }}</i>
                          <h6>My Orders</h6>
                          <p>Check your order status</p>
                        </div>
                        <div class="dashbaord-card">
                          <i class="svg-wrapper">{{ "new-icon-wishlight.svg" | inline_asset_content }}</i>
                          <h6>Wishlist</h6>
                          <p>Check your order status</p>
                        </div>
                        <div class="dashbaord-card">
                          <i class="svg-wrapper">{{ "new-icon-offer.svg" | inline_asset_content }}</i>
                          <h6>Coupons</h6>
                          <p>Check your order status</p>
                        </div>
                      </div>
                        
                    </div>



                    <div class="tab-pane fade" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                        <h3>My Orders</h3> {% paginate customer.orders by 10 %} {% if customer.orders.size > 0 %}
                        <ul>
                            {% for order in customer.orders %}
                            <li>
                                {{ order.name }} - {{ order.created_at | date: '%B %d, %Y' }} - {{
                                order.financial_status_label }}
                            </li>
                            {% endfor %}
                        </ul>
                        {{ paginate | default_pagination }} {% else %}
                        <p>You have no orders yet.</p>
                        {% endif %} {% endpaginate %}
                    </div>





                    <div class="tab-pane fade" id="returns" role="tabpanel" aria-labelledby="returns-tab">
                        <h3>Returns</h3>
                        <p>Manage your returns here. Contact support for assistance.</p>
                        <!-- Add a link to a custom returns page or app if available -->
                        <a href="/pages/returns" class="btn btn-primary">View Returns</a>
                    </div>
                    <div class="tab-pane fade" id="offers" role="tabpanel" aria-labelledby="offers-tab">
                        <h3>Offers/Coupons</h3>
                        <p>View your available offers and coupons.</p>
                        <div id="offers-content">
                            <p>Loading offers...</p>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
               <div class="account-wrapper">
                          <h2>Edit Profile</h2>
                        
                          <form id="update-profile-form">
                            <div class="field">
                              <label for="first_name">First Name</label>
                              <input type="text" id="first_name" name="first_name" value="">
                            </div>
                        
                            <div class="field">
                              <label for="last_name">Last Name</label>
                              <input type="text" id="last_name" name="last_name" value="">
                            </div>
                        
                            <div class="field">
                              <label for="email">Email</label>
                              <input type="email" id="email" name="email" value="" readonly>
                            </div>
                        
                            <div class="field">
                              <label for="phone">Phone</label>
                              <input type="tel" id="phone" name="phone" value="">
                            </div>
                        
                            <input type="hidden" id="customer_id" value="{{ customer.id }}">
                            <button type="submit" class="btn">Update Profile</button>
                            <p id="update-msg" style="margin-top:10px;"></p>
                          </form>
                 
                        </div>
                    </div>
                    <div class="tab-pane fade" id="wishlist" role="tabpanel" aria-labelledby="wishlist-tab">
                        <h3>Wishlist</h3>
                        <div id="wishlist-content">
                            <p>Loading wishlist...</p>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="shipping" role="tabpanel" aria-labelledby="shipping-tab">
                        <h3>Shipping Addresses</h3> {% for address in customer.addresses %}
                        <div class="address-card">
                            <p>
                                {{ address.address1 }}, {{ address.city }}, {{ address.province_code }} {{ address.zip
                                }} {{ address.country }}
                            </p>
                            <a href="/account/addresses/{{ address.id }}" class="btn btn-secondary">Edit</a>
                            <form action="/account/addresses/{{ address.id }}" method="post">
                                <input type="hidden" name="_method" value="delete">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                        {% endfor %}
                        <a href="/account/addresses" class="btn btn-primary">Add Address</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



