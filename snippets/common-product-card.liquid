<div class="ijl-product-card" data-product-id="{{ product.id }}">
  <div class="ijl-product-card-image-action">
    <a 
      {% if product.available %}
        href="
          {{ product.url }}
          " 
          {% else %}
        {% endif %}
      
      
      style="text-decoration:none">
      <div class="ijl-product-card-image">
        {% if product.featured_image %}
          <img
            class="ijl-product-image-one active-image"
            src="{{ product.featured_image | img_url: 'grande' }}"
            alt="{{ product.title | escape }}"
            data-default-image="{{ product.featured_image | img_url: 'grande' }}"
          >
        {% endif %}
        {% if product.images[1] %}
          <img
            class="ijl-product-image-two"
            src="{{ product.images[1] | img_url: 'grande' }}"
            alt="{{ product.title | escape }}"
          >
        {% endif %}
      </div>
    </a>
    <div class="ijl-product-card-imae-action-wrapper">
      <div class="ijl-product-card-action">
        <div class="ijl-product-card-action-tag-wrapper">
          {% if product.compare_at_price > product.price %}
            <div class="ijl-product-card-action-tag tag tag-primary">
              Sale
              {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
            </div>
          {% endif %}

          {% if product.available %}
            {% else %}
            <div class="ijl-product-card-action-tag tag tag-danger">
              Out Of Stock
            </div>
          {% endif %}




          {% if product.tags contains 'new' %}
            <div class="ijl-product-card-action-tag tag tag-secondary">New</div>
          {% endif %}
        </div>
        <div class="ijl-product-card-action-icon-wrapper">
          <!-- <button
            class="wishlist-btn ijl-product-card-action-icon "
            data-product-handle="{{ product.handle }}"
            data-product-price="{{ product.price | money_without_currency }}"
            data-product-image="{{ product.featured_image | img_url: '300x300' }}"
            data-icon-default="{{ 'new-icon-wishlight.svg' | asset_url }}"
            data-icon-filled="{{ 'new-icon-wishlight-fill.svg' | asset_url }}"
          >
            <img class="wishlist-icon" src="{{ 'new-icon-wishlight.svg' | asset_url }}" alt="Add to wishlist">
          </button> -->

          <div class="ijl-product-card-action-icon wishlist-main">
             {% render 'wishlisthero-collection-product' with product: product %}
          </div>


          {% comment %} <button
            type="button"
            id="quick-view-btn"
            class="ijl-product-card-action-icon btn-icon-hover-action"
            data-product-handle="{{ product.handle }}"
          >
            <img src="{{ 'new-icon-quick-view.svg' | asset_url }}" alt="Quick View">
          </button> {% endcomment %}
        </div>
      </div>
      <div class="ijl-product-card-action-button-wrapper d-none">
    


      </div>
    </div>
  </div>
  <div class="ijl-product-card-content">
    <div class="ijl-product-title cursor-pointer" onclick="window.location.href='{{ product.url }}'">
      <h6>{{ product.title }}</h6>
      <div class="ijl-product-price">
        <h5>
          {% if product.price_varies %}
            {{ product.price_min | money }} - {{ product.price_max | money }}
          {% else %}
            {{ product.price | money }}
          {% endif %}
          {% if product.variants.first.compare_at_price > product.variants.first.price %}
              <span class="line-through text-gray-500">
                {{ product.variants.first.compare_at_price | money }}
              </span>
          {% endif %}
        </h5>
      </div>
    </div>
    <div class="ijl-product-main-button">

            {% comment %} <button
          type="button"
          class="ijl-product-card-action-button btn  btn-light-primary {% unless product.available %}disabled{% endunless %}"
          onclick="window.location.href='{{ product.url }}'"
          {% unless product.available %}
            disabled
          {% endunless %}
        >
          Buy Now
        </button> {% endcomment %}

      
        <!-- Add to Cart Button -->
        {% if product.variants.size > 1 %}
          <button
            type="button"
            class="ijl-product-card-action-button btn  btn-light-primary {% unless product.available %}disabled{% endunless %}"
            onclick="window.location.href='{{ product.url }}'"
            {% unless product.available %}
              disabled
            {% endunless %}
          >
            Add to Cart
          </button>
        {% else %}
          <form action="/cart/add" method="post" class="add-to-cart-form w-100">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="button"
              class="ijl-product-card-action-button btn btn-light-primary {% unless product.available %}disabled{% endunless %}"
              onclick="{% if product.available %}addToCartWithDawn('{{ product.variants.first.id }}'){% endif %}"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {% if product.available %}
                Add to Cart
              {% else %}
                Out Of Stock
              {% endif %}
            </button>



            
          </form>

        {% endif %}
    </div>

    
    <div class="ijl-product-variation-metal-wrapper d-none">
      {% if product.options contains 'Color' %}
        <div class="ijl-product-variation">
          {% for variant in product.variants %}
            {% if variant.available and variant.option1 %}
              <div class="ijl-product-variation-item">
                <span
                  class="variant-swatch"
                  style="background-color: {{ variant.option1 | downcase }};"
                  title="{{ variant.option1 }}"
                  data-variant-id="{{ variant.id }}"
                  data-image-url="{% if variant.image %}{{ variant.image | img_url: 'grande' }}{% else %}{{ product.featured_image | img_url: 'grande' }}{% endif %}"
                ></span>
              </div>
              <!-- DEBUG: {{ variant.image | img_url: 'grande' }} -->
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
      <!--
        <div class="ijl-product-metal-text">
           <p>{{ product.description | strip_html | truncate: 100 }}</p>
        </div>
      -->      
    </div>
  </div>
</div>







