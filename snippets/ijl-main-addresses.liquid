{%- paginate customer.addresses by 5 -%}
  <div class=" addresses p-0 mw-100 " data-customer-addresses>

    <div class="tab-title">

      <div class="tab-title-wrapper">
        <h2>Shipping Addresses</h2>
        <button
        type="button"
        class="btn btn-primary add-address-button m-0"
        data-bs-toggle="modal"
        data-bs-target="#modalAddAddress"
        aria-expanded="false"
        aria-controls="modalAddAddress"
      >
        {{ 'customer.addresses.add_new' | t }}
      </button>
      </div>
     </div>
    <!-- <h1>{{ 'customer.addresses.title' | t }}</h1>
    <a href="{{ routes.account_url }}">
      {{ 'customer.account.return' | t }}
    </a> -->

    <!-- Add Address Button -->
    <div class="address-actions text-center my-4">
      
    </div>

    <ul role="list" class="address-list">
      {%- for address in customer.addresses -%}
        <li data-address class="address-item">
          {%- if address == customer.default_address -%}
            <!-- <h2>{{ 'customer.addresses.default' | t }}</h2> -->
          {%- endif -%}
          {{ address | format_address }}
          <div class="address-actions">
            <button
              type="button"
              class="btn btn-primary btn-sm edit-address-button"
              data-bs-toggle="modal"
              data-bs-target="#modalEditAddress_{{ address.id }}"
              data-address-id="{{ address.id }}"
              aria-expanded="false"
              aria-controls="modalEditAddress_{{ address.id }}"
            >
              <i class="svg-wrapper">{{ "new-icon-edit.svg" | inline_asset_content }}</i>
              {{ 'customer.addresses.edit' | t }}
            </button>
            <button
              type="button"
              class="btn btn-danger btn-sm delete-address-button"
              data-target="{{ address.url }}"
              data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}"
            >
              {{ 'customer.addresses.delete' | t }}
            </button>
          </div>
        </li>
      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      {%- if paginate.parts.size > 0 -%}
        <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
          <ul role="list">
            {%- if paginate.previous -%}
              <li>
                <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </a>
              </li>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              <li>
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                    {{- part.title -}}
                  </a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                      {{- part.title -}}
                    </span>
                  {%- else -%}
                    <span>{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              </li>
            {%- endfor -%}

            {%- if paginate.next -%}
              <li>
                <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </a>
              </li>
            {%- endif -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- endif -%}
  </div>
  
{%- endpaginate -%}

<!-- Add Address Modal -->
<div class="modal fade m-0"  id="modalAddAddress" tabindex="-1" aria-labelledby="modalAddAddressLabel" aria-hidden="true">
  <div class="modal-dialog  modal-dialog-centered modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title">
          <h2 class="" id="modalAddAddressLabel">{{ 'customer.addresses.add_new' | t }}</h2>
          <p>Add below details to add new address</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="AddAddress">
          {%- form 'customer_address', customer.new_address, aria_labelledby: 'AddressNewHeading' -%}

          <div class="row">
              <div class="col-md-6">
                  <div class="form-group">
                    <label for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
                    <input
                      type="text"
                      id="AddressFirstNameNew"
                      name="address[first_name]"
                      class="form-control"
                      value="{{ form.first_name }}"
                      autocomplete="given-name"
                      placeholder="{{ 'customer.addresses.first_name' | t }}"
                      required
                    >
                  </div>
              </div>
              <div class="col-md-6">
                  <div class="form-group">
                    <label for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
                    <input
                      type="text"
                      id="AddressLastNameNew"
                      name="address[last_name]"
                      class="form-control"
                      value="{{ form.last_name }}"
                      autocomplete="family-name"
                      placeholder="{{ 'customer.addresses.last_name' | t }}"
                      required
                    >
                  </div>
              </div>
          </div>
            <div class="form-group">
              <label for="AddressCompanyNew">{{ 'customer.addresses.company' | t }}</label>
              <input
                type="text"
                id="AddressCompanyNew"
                class="form-control"
                name="address[company]"
                value="{{ form.company }}"
                autocomplete="organization"
                placeholder="{{ 'customer.addresses.company' | t }}"
              >
            </div>
            <div class="form-group">
              <label for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
              <input
                type="text"
                id="AddressAddress1New"
                class="form-control"
                name="address[address1]"
                value="{{ form.address1 }}"
                autocomplete="address-line1"
                placeholder="{{ 'customer.addresses.address1' | t }}"
                required
              >
            </div>
            <div class="form-group">
              <label for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
              <input
                type="text"
                id="AddressAddress2New"
                class="form-control"
                name="address[address2]"
                value="{{ form.address2 }}"
                autocomplete="address-line2"
                placeholder="{{ 'customer.addresses.address2' | t }}"
              >
            </div>

            <div class="row">
              <div class="col-md-4">
                 <div class="form-group">
                  <label for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
                  <input
                    type="text"
                    id="AddressCityNew"
                    class="form-control"
                    name="address[city]"
                    value="{{ form.city }}"
                    autocomplete="address-level2"
                    placeholder="{{ 'customer.addresses.city' | t }}"
                    required
                  >
                </div>
              </div>
              <div class="col-md-4">
                <div class="form-group">
                  <label for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
                  <div class="select">
                    <select
                      id="AddressCountryNew"
                      name="address[country]"
                      data-default="{{ form.country }}"
                      autocomplete="country"
                      class="form-control form-select"
                      required
                    >
                      {{ all_country_option_tags }}
                    </select>
                    <span class="svg-wrapper">
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </span>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="form-group">
                  <label for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
                  <input
                    type="text"
                    id="AddressZipNew"
                    class="form-control"
                    name="address[zip]"
                    value="{{ form.zip }}"
                    autocapitalize="characters"
                    autocomplete="postal-code"
                    placeholder="{{ 'customer.addresses.zip' | t }}"
                    required
                  >
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
              <input
                type="tel"
                id="AddressPhoneNew"
                class="form-control"
                name="address[phone]"
                value="{{ form.phone }}"
                autocomplete="tel"
                placeholder="{{ 'customer.addresses.phone' | t }}"
              >
            </div>
           
            
            
            
            <div class="d-flex">
              {{ form.set_as_default_checkbox }}
              <label for="address_default_address_new">{{ 'customer.addresses.set_default' | t }}</label>
            </div>
        </div>
      </div>
      <div class="modal-footer">
          <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">{{ 'customer.addresses.cancel' | t }}</button>
          <button type="submit" class="btn btn-primary">{{ 'customer.addresses.add' | t }}</button>
        </div>
         {%- endform -%}
    </div>
  </div>
 </div>
<!-- Edit Address Modal (Dynamic per Address) -->
{%- for address in customer.addresses -%}
  <div class="modal fade m-0" id="modalEditAddress_{{ address.id }}" tabindex="-1" aria-labelledby="modalEditAddressLabel_{{ address.id }}" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <div class="modal-title">
            <h2 class="modal-title" id="modalEditAddressLabel_{{ address.id }}">{{ 'customer.addresses.edit_address' | t }}</h2>
            <p>Add below details to add new address</p>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="EditAddress_{{ address.id }}">
            {%- form 'customer_address', address -%}
                    <div class="row">
                      <div class="col-md-6">
                        <div class="form-group">
                          <label for="AddressFirstName_{{ form.id }}">{{ 'customer.addresses.first_name' | t }}</label>
                          <input type="text" id="AddressFirstName_{{ form.id }}" name="address[first_name]" class="form-control"
                            value="{{ form.first_name }}" autocomplete="given-name" placeholder="{{ 'customer.addresses.first_name' | t }}"
                            required>
                        </div>
                      </div>
                      <div class="col-md-6">
                        <div class="form-group">
                          <label for="AddressLastName_{{ form.id }}">{{ 'customer.addresses.last_name' | t }}</label>
                          <input type="text" id="AddressLastName_{{ form.id }}" name="address[last_name]" value="{{ form.last_name }}"
                            class="form-control" autocomplete="family-name" placeholder="{{ 'customer.addresses.last_name' | t }}" required>
                        </div>
                      </div>
                    </div>
            
                <div class="form-group">
                  <label for="AddressCompany_{{ form.id }}">{{ 'customer.addresses.company' | t }}</label>
                  <input type="text" id="AddressCompany_{{ form.id }}" name="address[company]" class="form-control"
                    value="{{ form.company }}" autocomplete="organization" placeholder="{{ 'customer.addresses.company' | t }}">
                </div>
                <div class="form-group">
                  <label for="AddressAddress1_{{ form.id }}">{{ 'customer.addresses.address1' | t }}</label>
                  <input type="text" id="AddressAddress1_{{ form.id }}" name="address[address1]" value="{{ form.address1 }}"
                    class="form-control" autocomplete="address-line1" placeholder="{{ 'customer.addresses.address1' | t }}"
                    required>
                </div>
                <div class="form-group">
                  <label for="AddressAddress2_{{ form.id }}">{{ 'customer.addresses.address2' | t }}</label>
                  <input type="text" id="AddressAddress2_{{ form.id }}" name="address[address2]" class="form-control"
                    value="{{ form.address2 }}" autocomplete="address-line2" placeholder="{{ 'customer.addresses.address2' | t }}">
                </div>

               <div class="row">
                  <div class="col-md-4">
            
                    <div class="form-group">
                      <label for="AddressCity_{{ form.id }}">{{ 'customer.addresses.city' | t }}</label>
                      <input type="text" id="AddressCity_{{ form.id }}" class="form-control" name="address[city]"
                        value="{{ form.city }}" autocomplete="address-level2" placeholder="{{ 'customer.addresses.city' | t }}"
                        required>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-group">
                      <label for="AddressCountry_{{ form.id }}">{{ 'customer.addresses.country' | t }}</label>
                      <div class="select">
                        <select id="AddressCountry_{{ form.id }}" name="address[country]" class="form-control from-select"
                          data-address-country-select data-default="{{ form.country }}" data-form-id="{{ form.id }}"
                          autocomplete="country" required>
                          {{ all_country_option_tags }}
                        </select>
                        <span class="svg-wrapper">
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-group">
                      <label for="AddressZip_{{ form.id }}">{{ 'customer.addresses.zip' | t }}</label>
                      <input type="text" id="AddressZip_{{ form.id }}" name="address[zip]" value="{{ form.zip }}"
                        autocapitalize="characters" class="form-control" autocomplete="postal-code"
                        placeholder="{{ 'customer.addresses.zip' | t }}" required>
                    </div>
                  </div>
                </div>

                <div class="form-group">
                  <label for="AddressPhone_{{ form.id }}">{{ 'customer.addresses.phone' | t }}</label>
                  <input type="tel" id="AddressPhone_{{ form.id }}" name="address[phone]" value="{{ form.phone }}"
                    class="form-control" autocomplete="tel" placeholder="{{ 'customer.addresses.phone' | t }}">
                </div>
                <div class="d-flex">
                  {{ form.set_as_default_checkbox }}
                  <label for="address_default_address_{{ form.id }}">{{ 'customer.addresses.set_default' | t }}</label>
                </div>

              
            
          </div>
        </div>
        <div class="modal-footer">
         <button type="submit" class="btn btn-primary">
          {{ 'customer.addresses.update' | t }}
          </button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'customer.addresses.cancel' | t }}</button>
        </div>
          {%- endform -%}
      </div>
    </div>
  </div>
{%- endfor -%}

<script>
  document.addEventListener("DOMContentLoaded", function () {
    {% for address in customer.addresses %}
      new Shopify.CountryProvinceSelector(
        'AddressCountry_{{ address.id }}',
        'AddressProvince_{{ address.id }}',
        {
          hideElement: 'AddressProvinceContainer_{{ address.id }}'
        }
      );
    {% endfor %}

    new Shopify.CountryProvinceSelector(
      'AddressCountryNew',
      'AddressProvinceNew',
      {
        hideElement: 'AddressProvinceContainerNew'
      }
    );
  });
</script>

